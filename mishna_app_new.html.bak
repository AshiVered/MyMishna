<body>
<div id="app"></div>
<button id="topBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>
<!-- CELEBRATION MODAL -->
<div id="celebModal">
 <div class="celeb-box">
  <div class="celeb-emoji">🎉</div>
  <div class="celeb-title">מזל טוב!</div>
  <div class="celeb-sub" id="celebSub"></div>
  <div class="celeb-stats" id="celebStats"></div>
  <div class="celeb-btns">
   <button class="celeb-btn celeb-btn-secondary" onclick="closeCeleb()">המשך</button>
   <button class="celeb-btn celeb-btn-primary" onclick="closeCeleb()">✓ סיימתי</button>
  </div>
 </div>
</div>
