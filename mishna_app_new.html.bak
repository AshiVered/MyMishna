<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>לוח לימוד משניות</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
 --blue:#2B4CB8;--blue2:#1e3a9f;--blue3:#4a6fd8;
 --green:#27ae60;--orange:#e67e22;--amber:#f59e0b;
 --purple:#8e44ad;--red:#e74c3c;
 --bg:#f0f4ff;--card:#fff;--border:#d0d8f0;
 --txt:#1a2240;--txt2:#4a5580;
 --sh:#fff9c4;--rev:#e3f2fd;--tract:#fff3e0;--hol:#f3e5f5;
 --radius:12px;--shadow:0 2px 12px rgba(43,76,184,.13);
}
body.dark{
 --bg:#0f0f1a;--card:#1a1a2e;--border:#2a2a4a;
 --txt:#e8e8ff;--txt2:#9090bb;
 --sh:#2a2800;--rev:#0a1a2e;--tract:#2a1a00;--hol:#1a0a2e;
}
body{font-family:'Segoe UI','Arial Hebrew',Arial,sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;direction:rtl;transition:background .2s,color .2s}
#app{min-height:100vh;padding-bottom:80px}
/* HEADER */
.hdr{background:var(--blue);color:#fff;padding:13px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.25)}
.hdr-title{font-size:17px;font-weight:700;flex:1;text-align:center}
.hdr-btn{background:rgba(255,255,255,.15);border:none;color:#fff;font-size:14px;cursor:pointer;padding:6px 10px;border-radius:8px;white-space:nowrap}
.hdr-btn:hover{background:rgba(255,255,255,.25)}
/* PROGRESS */
.progress{background:var(--blue2);padding:10px 8px;display:flex;gap:4px;align-items:flex-start;justify-content:center}
.p-wrap{display:flex;flex-direction:column;align-items:center;gap:3px}
.p-step{width:32px;height:32px;border-radius:50%;border:2px solid rgba(255,255,255,.35);color:rgba(255,255,255,.55);font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center}
.p-step.active{background:var(--blue);border-color:#fff;color:#fff;box-shadow:0 0 0 3px rgba(255,255,255,.25)}
.p-step.done{background:var(--green);border-color:var(--green);color:#fff}
.p-label{font-size:9px;color:rgba(255,255,255,.65);text-align:center}
.p-conn{height:2px;flex:1;background:rgba(255,255,255,.25);max-width:16px;margin-top:16px}
/* CARDS */
.card{background:var(--card);border-radius:var(--radius);padding:16px;margin:10px 12px;box-shadow:var(--shadow)}
/* WIZARD */
.wiz-body{padding-bottom:4px}
.step-title{font-size:19px;font-weight:800;color:var(--txt);text-align:center;padding:16px 16px 4px}
.step-sub{font-size:13px;color:var(--txt2);text-align:center;padding:0 16px 12px}
/* BOOK SELECTOR */
.book-wrap{margin:6px 12px;border:2px solid var(--border);border-radius:var(--radius);overflow:hidden;background:var(--card)}
.book-hdr{padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:.15s}
.book-hdr:hover{background:var(--bg)}
.book-hdr input[type=checkbox]{accent-color:var(--blue);width:18px;height:18px;cursor:pointer;flex-shrink:0}
.book-name{font-size:15px;font-weight:700;flex:1}
.book-count{font-size:11px;color:var(--txt2)}
.book-toggle{color:var(--blue);font-size:16px;transition:.2s;flex-shrink:0}
.tract-list{max-height:0;overflow:hidden;transition:max-height .3s}
.tract-list.open{max-height:700px}
.tract-item{padding:9px 14px 9px 18px;display:flex;align-items:center;gap:10px;border-top:1px solid var(--border);cursor:pointer}
.tract-item:hover{background:var(--bg)}
.tract-item input[type=checkbox]{accent-color:var(--blue);width:15px;height:15px}
.tract-label{font-size:13px;flex:1}
.tract-info{font-size:10px;color:var(--txt2)}
/* PACE */
.pace-tabs{display:flex;gap:10px;padding:0 12px 10px}
.pace-tab{flex:1;padding:13px 8px;border:2px solid var(--border);border-radius:var(--radius);text-align:center;cursor:pointer;background:var(--card);font-size:13px;font-weight:600;color:var(--txt2);transition:.15s}
.pace-tab.active{background:var(--blue);border-color:var(--blue);color:#fff}
.counter-box{background:var(--card);border-radius:var(--radius);padding:14px;margin:0 12px 10px;border:2px solid var(--border)}
.counter-label{font-size:13px;font-weight:600;margin-bottom:10px;text-align:center;color:var(--txt2)}
.counter-row{display:flex;align-items:center;justify-content:center;gap:14px}
.cnt-btn{width:42px;height:42px;border-radius:50%;border:2px solid var(--blue);background:var(--card);color:var(--blue);font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700}
.cnt-btn:hover{background:var(--blue);color:#fff}
.cnt-val{font-size:40px;font-weight:800;color:var(--blue);min-width:58px;text-align:center}
.date-box{margin:0 12px 10px;background:var(--card);border-radius:var(--radius);padding:12px;border:2px solid var(--border)}
.date-label{font-size:13px;font-weight:600;color:var(--txt2);margin-bottom:6px;display:block;text-align:center}
.date-input{width:100%;padding:9px;border:2px solid var(--border);border-radius:8px;font-size:15px;text-align:center;direction:ltr;outline:none;background:var(--card);color:var(--txt)}
.date-input:focus{border-color:var(--blue)}
/* TOGGLE */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--border)}
.toggle-row:last-child{border-bottom:none}
.toggle-label{font-size:14px;font-weight:600}
.toggle-sub{font-size:11px;color:var(--txt2);margin-top:1px}
.switch{position:relative;display:inline-block;width:48px;height:25px}
.switch input{opacity:0;width:0;height:0}
.slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#ccc;border-radius:25px;transition:.3s}
.slider:before{position:absolute;content:"";height:19px;width:19px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.3s}
input:checked+.slider{background:var(--blue)}
input:checked+.slider:before{transform:translateX(23px)}
/* RADIO GROUP */
.radio-group{display:flex;gap:8px;padding:0 12px 10px;flex-wrap:wrap}
.radio-item{padding:10px 14px;border:2px solid var(--border);border-radius:10px;cursor:pointer;font-size:13px;font-weight:600;color:var(--txt2);background:var(--card)}
.radio-item.sel{border-color:var(--blue);background:#eef2ff;color:var(--blue)}
body.dark .radio-item.sel{background:#1a2060}
/* DAYS SELECTOR */
.days-row{display:flex;gap:6px;flex-wrap:wrap;padding:8px 0}
.day-btn{width:40px;height:40px;border-radius:50%;border:2px solid var(--border);background:var(--card);color:var(--txt2);font-size:13px;font-weight:700;cursor:pointer}
.day-btn.sel{border-color:var(--blue);background:var(--blue);color:#fff}
/* NAV BUTTONS */
.nav-row{position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--border);padding:10px 14px;display:flex;gap:10px;z-index:200}
.btn{flex:1;padding:13px;border-radius:var(--radius);font-size:15px;font-weight:700;cursor:pointer;border:none}
.btn-back{background:var(--bg);color:var(--blue);border:2px solid var(--blue)}
.btn-next{background:var(--blue);color:#fff;box-shadow:0 4px 12px rgba(43,76,184,.3)}
.btn-save{background:var(--green);color:#fff}
/* SUMMARY */
.sum-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border)}
.sum-row:last-child{border-bottom:none}
.sum-key{font-size:12px;color:var(--txt2)}
.sum-val{font-size:13px;font-weight:700;color:var(--txt)}
/* STATS BAR */
.stats-bar{background:var(--card);padding:10px 14px;border-bottom:1px solid var(--border);display:flex;gap:12px;align-items:center;flex-wrap:wrap}
.stat-item{text-align:center;flex:1;min-width:60px}
.stat-num{font-size:18px;font-weight:800;color:var(--blue)}
.stat-lbl{font-size:10px;color:var(--txt2);margin-top:1px}
.progress-track{height:6px;background:var(--border);border-radius:3px;flex:3;min-width:80px}
.progress-fill{height:100%;background:var(--green);border-radius:3px;transition:width .4s}
/* CALENDAR */
.cal-hdr{background:var(--blue);color:#fff;padding:10px 14px;display:flex;align-items:center;justify-content:space-between}
.cal-hdr-title{font-size:16px;font-weight:700;text-align:center}
.cal-nav{background:none;border:none;color:#fff;font-size:20px;cursor:pointer;padding:4px 10px;border-radius:8px}
.cal-nav:hover{background:rgba(255,255,255,.2)}
.cal-actions{display:flex;gap:8px;padding:8px 12px;background:var(--card);border-bottom:1px solid var(--border);align-items:center}
.cal-act-btn{padding:8px 12px;border-radius:8px;border:2px solid var(--blue);background:var(--card);color:var(--blue);font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap}
.cal-act-btn:hover{background:var(--bg)}
.jump-input{padding:7px;border:2px solid var(--border);border-radius:8px;font-size:13px;direction:ltr;outline:none;background:var(--card);color:var(--txt);flex:1;min-width:0}
.jump-input:focus{border-color:var(--blue)}
.cal-days-hdr{display:grid;grid-template-columns:repeat(7,1fr);background:var(--blue2)}
.cal-day-name{padding:7px 2px;text-align:center;font-size:10px;font-weight:700;color:rgba(255,255,255,.85)}
.cal-day-name.shabbat{color:#ffd54f}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--border)}
/* CELLS */
.cal-cell{background:var(--card);min-height:90px;padding:3px;position:relative;overflow:hidden;cursor:pointer;transition:filter .1s}
.cal-cell:hover{filter:brightness(.95)}
.cal-cell.other-month{background:var(--bg);opacity:.55}
.cal-cell.today{outline:2px solid var(--blue3);outline-offset:-2px}
.cal-cell.shabbat-cell{background:var(--sh)}
.cal-cell.review-cell{background:var(--rev)}
.cal-cell.tract-review-cell{background:var(--tract)}
.cal-cell.holiday-cell{background:var(--hol)}
.cal-cell.done-cell{border-top:3px solid var(--green)}
.cell-greg{position:absolute;right:3px;top:2px;font-size:12px;font-weight:700;color:var(--txt)}
.cell-heb{position:absolute;left:3px;top:2px;font-size:9px;color:var(--txt2);font-weight:600;line-height:1.2}
.cell-dayname{text-align:center;font-size:9px;color:var(--txt2);margin-top:20px;font-weight:600}
.cell-content{text-align:center;margin-top:3px;font-size:9px;color:var(--txt);line-height:1.35;font-weight:600}
.cell-tag{text-align:center;font-size:8px;border-radius:3px;padding:1px 3px;margin-top:2px;font-weight:600}
.tag-parasha{color:#7b5e00;background:#fff3cd}
.tag-holiday{color:#6a1b9a;background:#f3e5f5}
.tag-rch{color:#1b5e20;background:#e8f5e9}
.tag-review{color:var(--blue2);background:#bbdefb}
.tag-tract{color:#bf6000;background:#ffe0b2}
.cell-done{position:absolute;left:3px;bottom:3px;font-size:11px;color:var(--green);font-weight:700}
.cell-star{position:absolute;right:3px;bottom:3px;font-size:11px}
/* LEGEND */
.legend{display:flex;flex-wrap:wrap;gap:6px;padding:8px 12px;background:var(--card);font-size:10px;border-top:1px solid var(--border)}
.leg-item{display:flex;align-items:center;gap:4px}
.leg-dot{width:12px;height:12px;border-radius:2px}
/* TOP BUTTON */
#topBtn{position:fixed;left:14px;bottom:85px;z-index:500;width:42px;height:42px;border-radius:50%;background:var(--blue);color:#fff;border:none;font-size:18px;cursor:pointer;box-shadow:0 4px 12px rgba(0,0,0,.25);display:none;align-items:center;justify-content:center}
/* CELEBRATION MODAL */
#celebModal{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:1000;display:none;align-items:center;justify-content:center;padding:20px}
#celebModal.show{display:flex}
.celeb-box{background:var(--card);border-radius:20px;padding:28px 24px;width:100%;max-width:340px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.3)}
.celeb-emoji{font-size:56px;margin-bottom:12px}
.celeb-title{font-size:22px;font-weight:800;color:var(--blue);margin-bottom:6px}
.celeb-sub{font-size:15px;color:var(--txt2);margin-bottom:18px}
.celeb-stats{display:flex;gap:16px;justify-content:center;margin-bottom:20px}
.celeb-stat{text-align:center}
.celeb-num{font-size:22px;font-weight:800;color:var(--orange)}
.celeb-lbl{font-size:11px;color:var(--txt2)}
.celeb-btns{display:flex;gap:10px}
.celeb-btn{flex:1;padding:12px;border-radius:10px;border:none;font-size:14px;font-weight:700;cursor:pointer}
.celeb-btn-primary{background:var(--blue);color:#fff}
.celeb-btn-secondary{background:var(--bg);color:var(--blue);border:2px solid var(--blue)}
/* DARK MODE SUPPORT */
body.dark .book-hdr:hover{background:rgba(255,255,255,.05)}
body.dark .tract-item:hover{background:rgba(255,255,255,.05)}
body.dark .cal-cell.today{outline-color:#7090ff}
body.dark .tag-parasha{color:#ffd54f;background:#332800}
body.dark .tag-holiday{color:#ce93d8;background:#2a0a3e}
body.dark .tag-rch{color:#81c784;background:#0a2e10}
body.dark .tag-review{color:#90caf9;background:#0a1a30}
body.dark .tag-tract{color:#ffb74d;background:#2e1a00}
@media(max-width:380px){.cal-cell{min-height:76px}.cnt-val{font-size:34px}}
</style>

