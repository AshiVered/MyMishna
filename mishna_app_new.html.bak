const M={
 "זרעים":{"ברכות":[5,8,6,7,5,8,5,8,5],"פאה":[6,8,8,11,8,11,8,9],"דמאי":[4,5,6,7,11,12,8],"כלאים":[9,11,7,9,8,9,8,6,10],"שביעית":[8,10,10,10,9,6,7,11,9,9],"תרומות":[10,6,9,13,9,6,7,12,7,12,10],"מעשרות":[8,8,10,6,8],"מעשר שני":[7,10,13,12,15],"חלה":[9,8,10,11],"ערלה":[9,17,9],"ביכורים":[11,11,12,5]},
